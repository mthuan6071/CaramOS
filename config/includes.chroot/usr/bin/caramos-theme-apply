#!/bin/bash
# Script để ép Cinnamon load đúng theme CaramOS + layout Cinnamon Delight
# Chạy 1 lần duy nhất vào lần đầu boot
sleep 0 # System defaults đã đúng; không trì hoãn wallpaper/theme

if [ -f "$HOME/.config/caramos-theme-applied" ]; then
    exit 0
fi

# ========== THEME ==========
gsettings set org.cinnamon.desktop.interface gtk-theme 'Cinnamon-Delight' 2>/dev/null || true
gsettings set org.cinnamon.desktop.interface icon-theme 'Tela-circle-light' 2>/dev/null || true
gsettings set org.cinnamon.desktop.interface cursor-theme 'Bibata-Modern-Classic' 2>/dev/null || true
gsettings set org.cinnamon.desktop.interface font-name 'Be Vietnam Pro 10' 2>/dev/null || true
gsettings set org.cinnamon.desktop.wm.preferences titlebar-font 'Be Vietnam Pro Bold 10' 2>/dev/null || true
gsettings set org.cinnamon.theme name 'Cinnamon-Delight' 2>/dev/null || true

# Wallpaper
WALLPAPER_URI='file:///usr/share/backgrounds/caramos/default.png'
gsettings set org.cinnamon.desktop.background picture-uri "$WALLPAPER_URI" 2>/dev/null || true
gsettings set org.gnome.desktop.background picture-uri "$WALLPAPER_URI" 2>/dev/null || true

# ========== CINNAMON LAYOUT ==========

# Panel nằm DƯỚI, giữ applets/taskbar như cấu hình dconf.
gsettings set org.cinnamon panels-enabled "['1:0:bottom']" 2>/dev/null || true
gsettings set org.cinnamon panels-autohide "['1:false']" 2>/dev/null || true
gsettings set org.cinnamon panels-height "['1:32']" 2>/dev/null || true
gsettings set org.cinnamon panel-zone-icon-sizes '[{"panelId": 1, "maxSize": 24}]' 2>/dev/null || true

# Desktop: ẩn TẤT CẢ icon trên desktop (desktop style)
gsettings set org.nemo.desktop computer-icon-visible false 2>/dev/null || true
gsettings set org.nemo.desktop home-icon-visible false 2>/dev/null || true
gsettings set org.nemo.desktop trash-icon-visible false 2>/dev/null || true
gsettings set org.nemo.desktop network-icon-visible false 2>/dev/null || true
gsettings set org.nemo.desktop volumes-visible false 2>/dev/null || true

# Nút cửa sổ bên phải (Windows style)
gsettings set org.cinnamon.desktop.wm.preferences button-layout ':minimize,maximize,close' 2>/dev/null || true

# Lock file — chạy 1 lần duy nhất
mkdir -p "$HOME/.config"
touch "$HOME/.config/caramos-theme-applied"
